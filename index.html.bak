<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kevo Amouzou | Ingénieur d'Affaires & Data Engineering</title>
    <meta name="description" content="Portfolio de Kevo Amouzou — Ingénieur d'Affaires, Chef de Projet Digital & Supply Chain. Double Master UTBM, 3x Oracle Certified. Disponible CDI août 2026.">
    <meta name="keywords" content="Kevo Amouzou, Supply Chain, Data Engineering, Oracle ERP, Chef de Projet, UTBM, Belfort">
    <meta property="og:title" content="Kevo Amouzou | Ingénieur d'Affaires & Data Engineering">
    <meta property="og:description" content="Double Master UTBM · 3× Oracle Certified · Disponible CDI Août 2026">

    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=general-sans@400,500,600&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['General Sans', 'sans-serif'],
                        display: ['Clash Display', 'sans-serif'],
                    },
                    colors: {
                        dark: '#0B0F19',
                        accent: '#00D4FF',
                        secondary: '#94A3B8'
                    }
                }
            }
        }
    </script>

    <style>
        * { box-sizing: border-box; }

        body {
            background-color: #0B0F19;
            color: #F8FAFC;
            overflow-x: hidden;
            font-family: 'General Sans', sans-serif;
        }

        /* ── NAV ── */
        .glass-nav {
            background: rgba(11, 15, 25, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }

        /* ── CARDS ── */
        .glass-card {
            background: rgba(18, 24, 38, 0.55);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.05);
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
        }
        .glass-card:hover {
            border-color: rgba(0,212,255,0.25);
            box-shadow: 0 12px 40px -12px rgba(0,212,255,0.12);
        }

        /* ── GRADIENT TEXTE ── */
        .text-accent-gradient {
            background: linear-gradient(135deg, #00D4FF 0%, #0055FF 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ── FOND AMBIANCE ── */
        .background-ambience {
            position: fixed;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
            z-index: -10;
        }
        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.25;
            animation: float 14s ease-in-out infinite;
        }
        .blob-1 {
            top: -15%; left: -10%;
            width: 560px; height: 560px;
            background: #00D4FF;
        }
        .blob-2 {
            bottom: -15%; right: -10%;
            width: 440px; height: 440px;
            background: #7C3AED;
        }
        @keyframes float {
            0%, 100% { transform: translate(0, 0); }
            33% { transform: translate(30px, -50px); }
            66% { transform: translate(-20px, 40px); }
        }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #0B0F19; }
        ::-webkit-scrollbar-thumb { background: #1E293B; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #00D4FF; }

        /* ── STATS HERO ── */
        .stat-card {
            background: rgba(0,212,255,0.04);
            border: 1px solid rgba(0,212,255,0.12);
            border-radius: 12px;
            padding: 12px;
            text-align: center;
        }

        /* ── CERTIF ORACLE ── */
        .cert-badge {
            background: linear-gradient(135deg, rgba(239,68,68,0.12), rgba(239,68,68,0.04));
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 14px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: border-color 0.3s ease;
        }
        .cert-badge:hover { border-color: rgba(239,68,68,0.5); }

        /* ── TIMELINE ── */
        .timeline-dot-active {
            box-shadow: 0 0 0 4px #0B0F19, 0 0 14px #00D4FF;
        }

        /* ── SKILL TAG ── */
        .skill-tag {
            font-size: 11px;
            padding: 4px 11px;
            border-radius: 6px;
            background: rgba(0,212,255,0.06);
            border: 1px solid rgba(0,212,255,0.15);
            color: #CBD5E1;
            display: inline-block;
            margin: 3px;
            transition: all 0.2s ease;
        }
        .skill-tag:hover {
            background: rgba(0,212,255,0.12);
            color: #00D4FF;
            border-color: rgba(0,212,255,0.3);
        }

        /* ── IMPACT BADGE ── */
        .impact-badge {
            background: rgba(0,212,255,0.05);
            border: 1px solid rgba(0,212,255,0.12);
            border-radius: 8px;
            padding: 6px 10px;
            font-size: 11px;
            color: #00D4FF;
            font-weight: 600;
        }

        /* ── MOBILE NAV ── */
        .mobile-menu {
            background: rgba(11,15,25,0.97);
            backdrop-filter: blur(16px);
        }
    </style>
</head>

<body class="antialiased" x-data="myPortfolio()">

    <div class="background-ambience">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <!-- ─────────────── NAV ─────────────── -->
    <nav class="fixed w-full z-50 glass-nav">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="flex items-center justify-between h-20">
                <a href="#" class="font-display font-bold text-2xl tracking-tight hover:text-accent transition-colors duration-200">
                    KEVO<span class="text-accent">.</span>
                </a>
                <div class="hidden md:flex items-center gap-8">
                    <a href="#about"      class="text-sm font-medium text-secondary hover:text-white transition-colors">À propos</a>
                    <a href="#skills"     class="text-sm font-medium text-secondary hover:text-white transition-colors">Compétences</a>
                    <a href="#projects"   class="text-sm font-medium text-secondary hover:text-white transition-colors">Projets</a>
                    <a href="#experience" class="text-sm font-medium text-secondary hover:text-white transition-colors">Parcours</a>
                    <a href="#contact"    class="px-5 py-2.5 rounded-full border border-white/10 bg-white/5 hover:bg-accent hover:text-dark hover:border-accent transition-all text-sm font-bold">
                        Me contacter
                    </a>
                </div>
                <!-- Mobile burger -->
                <button @click="mobileOpen = !mobileOpen" class="md:hidden p-2 text-secondary hover:text-white" aria-label="Basculer le menu">
                    <i class="ph ph-list text-2xl" x-show="!mobileOpen" aria-hidden="true"></i>
                    <i class="ph ph-x text-2xl" x-show="mobileOpen" aria-hidden="true"></i>
                </button>
            </div>
        </div>
        <!-- Mobile menu -->
        <div x-show="mobileOpen" x-transition class="mobile-menu md:hidden border-t border-white/5 px-6 py-6 flex flex-col gap-5">
            <a @click="mobileOpen=false" href="#about"      class="text-sm font-medium text-secondary hover:text-white">À propos</a>
            <a @click="mobileOpen=false" href="#skills"     class="text-sm font-medium text-secondary hover:text-white">Compétences</a>
            <a @click="mobileOpen=false" href="#projects"   class="text-sm font-medium text-secondary hover:text-white">Projets</a>
            <a @click="mobileOpen=false" href="#experience" class="text-sm font-medium text-secondary hover:text-white">Parcours</a>
            <a @click="mobileOpen=false" href="#contact"    class="text-sm font-bold text-accent">Me contacter →</a>
        </div>
    </nav>

    <!-- ─────────────── HERO ─────────────── -->
    <section id="about" class="relative min-h-screen flex items-center pt-20 px-6">
        <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-16 items-center py-20">

            <div class="gsap-hero-text order-2 lg:order-1">

                <!-- Badge disponibilité -->
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/8 text-emerald-400 text-xs font-semibold mb-8 tracking-wide">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    Disponible CDI — Août 2026 &nbsp;·&nbsp; France & Europe
                </div>

                <h1 class="font-display text-5xl lg:text-[68px] font-bold leading-[1.08] mb-6 tracking-tight">
                    Ingénieur<br>d'Affaires &<br>
                    <span class="text-accent-gradient">Data Engineering.</span>
                </h1>

                <p class="text-secondary text-lg leading-relaxed max-w-lg mb-8">
                    Double Master <strong class="text-white font-semibold">UTBM</strong> · <strong class="text-white font-semibold">3× Oracle Certified</strong> ·
                    Supply Chain & Transformation Digitale. Je pilote des projets à impact mesurable —
                    de l'ERP terrain à la BI stratégique.
                </p>

                <!-- KPIs -->
                <div class="grid grid-cols-3 gap-3 mb-10">
                    <div class="stat-card">
                        <div class="font-display text-2xl font-bold text-accent mb-1">+15</div>
                        <div class="text-xs text-secondary leading-tight">Dashboards Metabase déployés</div>
                    </div>
                    <div class="stat-card">
                        <div class="font-display text-2xl font-bold text-accent mb-1">80%</div>
                        <div class="text-xs text-secondary leading-tight">Réduction saisie manuelle</div>
                    </div>
                    <div class="stat-card">
                        <div class="font-display text-2xl font-bold text-accent mb-1">500+</div>
                        <div class="text-xs text-secondary leading-tight">Utilisateurs chatbot IA</div>
                    </div>
                </div>

                <div class="flex flex-wrap gap-4">
                    <a href="#projects"
                       class="px-8 py-4 rounded-full bg-accent text-dark font-bold text-sm hover:bg-white transition-colors shadow-[0_0_24px_rgba(0,212,255,0.25)] focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-dark">
                        Voir mes projets
                    </a>
                    <a href="./CV_Kevo_Amouzou.pdf" target="_blank" rel="noopener noreferrer"
                       class="px-8 py-4 rounded-full border border-white/10 bg-white/3 hover:bg-white/8 transition-colors flex items-center gap-2 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-dark" aria-label="Télécharger CV (nouvelle fenêtre)">
                        Télécharger CV <i class="ph ph-download-simple" aria-hidden="true"></i>
                    </a>
                </div>
            </div>

            <!-- Photo -->
            <div class="gsap-hero-img order-1 lg:order-2 flex justify-center lg:justify-end">
                <div class="relative w-72 h-72 lg:w-[380px] lg:h-[380px]">
                    <div class="absolute inset-0 bg-accent rounded-full blur-[110px] opacity-20"></div>
                    <img src="./images/kevo.jpeg"
                         alt="Kevo Amouzou - Portrait professionnel"
                         class="relative z-10 w-full h-full object-cover rounded-[2rem] border border-white/10 shadow-2xl grayscale hover:grayscale-0 transition-all duration-700 rotate-2 hover:rotate-0 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-dark"
                         loading="lazy">
                </div>
            </div>

        </div>
    </section>

    <!-- ─────────────── CERTIFICATIONS ORACLE ─────────────── -->
    <section class="py-14 border-y border-white/5">
        <div class="max-w-5xl mx-auto px-6">
            <p class="text-center text-xs font-semibold uppercase tracking-[3px] text-secondary/60 mb-10">
                Certifications Oracle
            </p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="cert-badge">
                    <div class="w-10 h-10 rounded-lg bg-red-500/15 flex items-center justify-center flex-shrink-0">
                        <i class="ph ph-medal text-red-400 text-xl"></i>
                    </div>
                    <div>
                        <div class="text-white text-sm font-bold leading-tight">Oracle Cloud GenAI</div>
                        <div class="text-secondary text-xs mt-0.5">Infrastructure 2024 · Professional</div>
                    </div>
                </div>
                <div class="cert-badge">
                    <div class="w-10 h-10 rounded-lg bg-red-500/15 flex items-center justify-center flex-shrink-0">
                        <i class="ph ph-medal text-red-400 text-xl"></i>
                    </div>
                    <div>
                        <div class="text-white text-sm font-bold leading-tight">Oracle ERP Foundations</div>
                        <div class="text-secondary text-xs mt-0.5">Fusion Cloud Applications · Associate</div>
                    </div>
                </div>
                <div class="cert-badge">
                    <div class="w-10 h-10 rounded-lg bg-red-500/15 flex items-center justify-center flex-shrink-0">
                        <i class="ph ph-medal text-red-400 text-xl"></i>
                    </div>
                    <div>
                        <div class="text-white text-sm font-bold leading-tight">Oracle AI Vector Search</div>
                        <div class="text-secondary text-xs mt-0.5">Certified Professional</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ─────────────── COMPÉTENCES ─────────────── -->
    <section id="skills" class="py-24">
        <div class="max-w-5xl mx-auto px-6">
            <div class="mb-16">
                <h2 class="font-display text-3xl lg:text-4xl font-bold mb-3 text-center">Compétences</h2>
                <p class="text-secondary text-center text-base max-w-sm mx-auto">Profil hybride — maîtrise technique avancée et vision industrielle business.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

                <div class="glass-card rounded-2xl p-6">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center">
                            <i class="ph ph-database text-accent text-lg"></i>
                        </div>
                        <h3 class="font-bold text-white text-sm">Data & Business Intelligence</h3>
                    </div>
                    <div class="flex flex-wrap">
                        <span class="skill-tag">SQL</span><span class="skill-tag">PostgreSQL</span><span class="skill-tag">MySQL</span>
                        <span class="skill-tag">Python</span><span class="skill-tag">Metabase</span><span class="skill-tag">Power BI</span>
                        <span class="skill-tag">dbt</span><span class="skill-tag">Apache Airflow</span><span class="skill-tag">VBA</span>
                    </div>
                </div>

                <div class="glass-card rounded-2xl p-6">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center">
                            <i class="ph ph-buildings text-accent text-lg"></i>
                        </div>
                        <h3 class="font-bold text-white text-sm">ERP & Systèmes d'Information</h3>
                    </div>
                    <div class="flex flex-wrap">
                        <span class="skill-tag">Oracle Fusion Cloud</span><span class="skill-tag">Dolibarr</span>
                        <span class="skill-tag">SharePoint</span><span class="skill-tag">Active Directory</span>
                        <span class="skill-tag">KeePass</span><span class="skill-tag">Git</span><span class="skill-tag">Docker</span>
                    </div>
                </div>

                <div class="glass-card rounded-2xl p-6">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center">
                            <i class="ph ph-code text-accent text-lg"></i>
                        </div>
                        <h3 class="font-bold text-white text-sm">Développement & IA</h3>
                    </div>
                    <div class="flex flex-wrap">
                        <span class="skill-tag">Flask</span><span class="skill-tag">FastAPI</span>
                        <span class="skill-tag">Spring Boot</span><span class="skill-tag">Angular</span>
                        <span class="skill-tag">RAG / GenAI</span><span class="skill-tag">Pinecone</span><span class="skill-tag">REST API</span>
                    </div>
                </div>

                <div class="glass-card rounded-2xl p-6">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center">
                            <i class="ph ph-truck text-accent text-lg"></i>
                        </div>
                        <h3 class="font-bold text-white text-sm">Supply Chain & Industrie</h3>
                    </div>
                    <div class="flex flex-wrap">
                        <span class="skill-tag">ISO 9001</span><span class="skill-tag">Incoterms 2020</span>
                        <span class="skill-tag">Lean Six Sigma</span><span class="skill-tag">DMAIC</span>
                        <span class="skill-tag">EOQ</span><span class="skill-tag">TOC</span><span class="skill-tag">Bid/No Bid</span>
                    </div>
                </div>

                <div class="glass-card rounded-2xl p-6">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center">
                            <i class="ph ph-kanban text-accent text-lg"></i>
                        </div>
                        <h3 class="font-bold text-white text-sm">Gestion de Projet</h3>
                    </div>
                    <div class="flex flex-wrap">
                        <span class="skill-tag">Agile / Scrum</span><span class="skill-tag">KANBAN</span>
                        <span class="skill-tag">PMI</span><span class="skill-tag">PERT / GANTT</span>
                        <span class="skill-tag">ADKAR</span><span class="skill-tag">PDCA</span><span class="skill-tag">Cahier des charges</span>
                    </div>
                </div>

                <div class="glass-card rounded-2xl p-6">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center">
                            <i class="ph ph-translate text-accent text-lg"></i>
                        </div>
                        <h3 class="font-bold text-white text-sm">Langues</h3>
                    </div>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-white">Français</span>
                            <span class="text-xs text-accent font-semibold bg-accent/10 px-2 py-0.5 rounded">Natif</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-white">Anglais</span>
                            <span class="text-xs text-accent font-semibold bg-accent/10 px-2 py-0.5 rounded">B2 — Pro</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-white">Polonais</span>
                            <span class="text-xs text-secondary bg-white/5 px-2 py-0.5 rounded">Courant</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-white">Espagnol</span>
                            <span class="text-xs text-secondary bg-white/5 px-2 py-0.5 rounded">A2</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- ─────────────── PROJETS ─────────────── -->
    <section id="projects" class="py-24 bg-black/15">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <h2 class="font-display text-3xl lg:text-4xl font-bold mb-3">Projets Réalisés</h2>
                    <p class="text-secondary max-w-md text-base">Projets professionnels et académiques en Supply Chain, Data Engineering et IA.</p>
                </div>
                <a href="https://github.com/amouzougit" target="_blank" rel="noopener noreferrer"
                   class="text-accent hover:text-white transition-colors flex items-center gap-2 text-sm font-semibold shrink-0 focus:outline-none focus:ring-2 focus:ring-accent rounded px-2 py-1" aria-label="Voir mon GitHub (nouvelle fenêtre)">
                    Voir mon GitHub <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <template x-for="project in projects" :key="project.title">
                    <article class="project-card glass-card rounded-2xl overflow-hidden group hover:-translate-y-1.5 transition-transform duration-300">
                        <div class="h-44 overflow-hidden relative">
                            <div class="absolute inset-0 bg-dark/50 group-hover:bg-dark/20 transition-all z-10 duration-500"></div>
                            <img :src="project.image" :alt="project.title"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                        </div>
                        <div class="p-6">
                            <div class="flex flex-wrap gap-1.5 mb-3">
                                <template x-for="tag in project.tags">
                                    <span class="text-[10px] font-bold px-2 py-1 rounded-md bg-accent/8 text-accent border border-accent/15" x-text="tag"></span>
                                </template>
                            </div>
                            <h3 class="font-display text-lg font-bold mb-2 text-white" x-text="project.title"></h3>
                            <p class="text-sm text-secondary mb-4 leading-relaxed" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;" x-text="project.desc"></p>
                            <template x-if="project.impact">
                                <div class="impact-badge mb-4" x-text="project.impact"></div>
                            </template>
                            <div class="flex items-center gap-5 pt-4 border-t border-white/5">
                                <template x-if="project.linkRepo">
                                    <a :href="project.linkRepo" target="_blank"
                                       class="text-white hover:text-accent text-xs flex items-center gap-1.5 font-semibold transition-colors">
                                        <i class="ph ph-github-logo text-base"></i> Code
                                    </a>
                                </template>
                                <template x-if="project.linkDemo">
                                    <a :href="project.linkDemo" target="_blank"
                                       class="text-secondary hover:text-white text-xs flex items-center gap-1.5 transition-colors">
                                        <i class="ph ph-arrow-square-out text-base"></i> Demo
                                    </a>
                                </template>
                                <template x-if="!project.linkRepo && !project.linkDemo">
                                    <span class="text-secondary/40 text-xs">Projet confidentiel</span>
                                </template>
                            </div>
                        </div>
                    </article>
                </template>
            </div>
        </div>
    </section>

    <!-- ─────────────── PARCOURS ─────────────── -->
    <section id="experience" class="py-24">
        <div class="max-w-3xl mx-auto px-6">
            <h2 class="font-display text-3xl lg:text-4xl font-bold mb-20 text-center">Mon Parcours</h2>

            <div class="relative border-l border-white/8 ml-5 pl-10 space-y-12">

                <!-- BH2M -->
                <div class="timeline-item relative">
                    <span class="absolute -left-[43px] top-1.5 w-4 h-4 rounded-full bg-accent timeline-dot-active"></span>
                    <div class="mb-1">
