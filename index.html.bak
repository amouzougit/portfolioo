    <!-- ─────────────── SCRIPTS ─────────────── -->
    <script>
        function myPortfolio() {
            return {
                mobileOpen: false,

                profil: {
                    github:   "https://github.com/amouzougit",
                    linkedin: "https://www.linkedin.com/in/kevo-amouzou",
                    email:    "kevoamouzou@gmail.com"
                },

                projects: [
                    {
                        title:   "Pilotage BI — BH2M",
                        desc:    "Déploiement de +15 tableaux de bord Metabase connectés à l'ERP Dolibarr pour le pilotage stratégique en temps réel d'un portefeuille de plusieurs M€. Développement d'un outil VBA/SQL automatisant +50 tâches quotidiennes.",
                        tags:    ["Metabase", "SQL", "VBA", "Dolibarr", "BI"],
                        impact:  "→ 80% de réduction du temps de saisie manuelle",
                        image:   "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80",
                        linkRepo: null,
                        linkDemo: null
                    },
                    {
                        title:   "Chatbot IA — RAG Architecture",
                        desc:    "Développement complet d'un chatbot intelligent pour 500+ utilisateurs. Architecture Flask / REST API avec Retrieval-Augmented Generation et base vectorielle Pinecone. Mission remote pour un client canadien.",
                        tags:    ["Python", "Flask", "RAG", "Pinecone", "GenAI"],
                        impact:  "→ 500+ utilisateurs · Mission internationale Canada",
                        image:   "https://images.unsplash.com/photo-1677442135703-1787eea5ce01?auto=format&fit=crop&w=800&q=80",
                        linkRepo: "https://github.com/amouzougit",
                        linkDemo: null
                    },
                    {
                        title:   "Supply Chain Resilience Twin",
                        desc:    "Jumeau numérique simulant les ruptures de flux d'approvisionnement automobile. Calcul des métriques TTS (Time-to-Survive) et TTR (Time-to-Recover) pour anticiper les disruptions supply chain.",
                        tags:    ["Python", "SimPy", "Supply Chain", "Digital Twin"],
                        impact:  "→ Métriques TTS & TTR industrie automobile",
                        image:   "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=800&q=80",
                        linkRepo: "https://github.com/amouzougit/SC_Resilience_Twin",
                        linkDemo: null
                    },
                    {
                        title:   "Urban Mobility Analytics",
                        desc:    "Pipeline ETL/ELT complet (Airflow, dbt, PostgreSQL) traitant des milliers de lignes de données Vélib' en temps réel. Tests unitaires pytest et contrôles qualité dbt intégrés en production.",
                        tags:    ["Airflow", "dbt", "PostgreSQL", "Python", "ETL"],
                        impact:  "→ Pipeline production avec tests automatisés",
                        image:   "https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=800&q=80",
                        linkRepo: "https://github.com/amouzougit/urban-mobility-analytics",
                        linkDemo: null
                    },
                    {
                        title:   "Digitalisation ISO 9001 — SharePoint",
                        desc:    "Conception et déploiement du portail intranet BH2M centralisant 100% des outils critiques. Modélisation complète du cycle Offre → ARC avec outils d'analyse Bid/No Bid pour sécuriser les décisions commerciales.",
                        tags:    ["SharePoint", "ISO 9001", "Intranet", "GED", "BPM"],
                        impact:  "→ 100% des processus métiers digitalisés",
                        image:   "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
                        linkRepo: null,
                        linkDemo: null
                    },
                    {
                        title:   "Modèle EOQ & Stocks de Sécurité",
                        desc:    "Dashboard interactif de pilotage des stocks intégrant modèle EOQ, point de commande et simulation de rupture. Visualisation Power BI + Streamlit pour aide à la décision logistique.",
                        tags:    ["Python", "Power BI", "Streamlit", "EOQ", "Supply Chain"],
                        impact:  "→ Optimisation et simulation des niveaux de stock",
                        image:   "https://images.unsplash.com/photo-1507925921958-8a62f3d1a50d?auto=format&fit=crop&w=800&q=80",
                        linkRepo: "https://github.com/amouzougit",
                        linkDemo: null
                    }
                ]
            }
        }

        window.addEventListener('load', () => {
            gsap.registerPlugin(ScrollTrigger);

            // Parallax blobs
            gsap.to(".blob-1", {
                yPercent: 45,
                ease: "none",
                scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: 2.5 }
            });
            gsap.to(".blob-2", {
                yPercent: -45,
                ease: "none",
                scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: 2.5 }
            });

            // Hero entrée
            gsap.from(".gsap-hero-text > *", {
                y: 28, opacity: 0, duration: 0.9,
                stagger: 0.1, delay: 0.15, ease: "power3.out"
            });
            gsap.from(".gsap-hero-img", {
                scale: 0.92, opacity: 0, duration: 1.1,
                delay: 0.3, ease: "power3.out"
            });

            // Projets cascade
            setTimeout(() => {
                gsap.set(".project-card", { y: 50, opacity: 0 });
                ScrollTrigger.batch(".project-card", {
                    start: "top 88%",
                    onEnter: batch => gsap.to(batch, {
                        opacity: 1, y: 0, stagger: 0.12,
                        duration: 0.75, ease: "back.out(1.5)", overwrite: true
                    })
                });
            }, 250);

            // Parcours
            gsap.from(".timeline-item", {
                scrollTrigger: { trigger: "#experience", start: "top 80%" },
                x: -24, opacity: 0, duration: 0.75, stagger: 0.18, ease: "power3.out"
            });

            // Skills
            gsap.from("#skills .glass-card", {
                scrollTrigger: { trigger: "#skills", start: "top 82%" },
                y: 24, opacity: 0, duration: 0.65, stagger: 0.08, ease: "power3.out"
            });

            // Contact
            gsap.from("#contact .glass-card", {
                scrollTrigger: { trigger: "#contact", start: "top 88%" },
                scale: 0.96, opacity: 0, duration: 0.9, ease: "power2.out"
            });
        });
    </script>

</body>
