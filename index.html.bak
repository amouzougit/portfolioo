    <section id="contact" class="py-24">
        <div class="max-w-lg mx-auto px-6">
            <div class="glass-card rounded-3xl p-8 border border-white/5">
                <h2 class="font-display text-2xl font-bold mb-2 text-center">Me contacter</h2>
                <p class="text-secondary text-sm text-center mb-8 leading-relaxed">
                    Recruteur, partenaire, ou simple curiosité —<br>je lis et réponds à chaque message.
                </p>

                <form action="https://formspree.io/f/mjknokbg" method="POST" class="space-y-3">
                    <input type="text" name="name" placeholder="Votre nom"
                           class="w-full bg-white/3 border border-white/8 rounded-xl px-4 py-3 text-sm text-white placeholder-secondary/60 focus:border-accent focus:ring-2 focus:ring-accent/30 focus:outline-none transition-colors"
                           required aria-label="Votre nom">
                    <input type="email" name="email" placeholder="Votre email"
                           class="w-full bg-white/3 border border-white/8 rounded-xl px-4 py-3 text-sm text-white placeholder-secondary/60 focus:border-accent focus:ring-2 focus:ring-accent/30 focus:outline-none transition-colors"
                           required aria-label="Votre email">
                    <textarea name="message" rows="4" placeholder="Votre message..."
                              class="w-full bg-white/3 border border-white/8 rounded-xl px-4 py-3 text-sm text-white placeholder-secondary/60 focus:border-accent focus:ring-2 focus:ring-accent/30 focus:outline-none transition-colors resize-none"
                              required aria-label="Votre message"></textarea>
                    <button type="submit"
                            class="w-full py-3.5 rounded-xl bg-accent text-dark font-bold text-sm hover:bg-white transition-colors flex items-center justify-center gap-2 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-dark focus:ring-white">
                        Envoyer <i class="ph ph-paper-plane-right" aria-hidden="true"></i>
                    </button>
                </form>

                <div class="mt-8 flex justify-center gap-6 pt-6 border-t border-white/5">
                    <a href="https://www.linkedin.com/in/kevo-amouzou" target="_blank" rel="noopener noreferrer"
                       class="text-secondary hover:text-accent text-2xl transition-colors focus:outline-none focus:ring-2 focus:ring-accent rounded-full p-1" aria-label="LinkedIn">
                        <i class="ph ph-linkedin-logo" aria-hidden="true"></i>
                    </a>
                    <a href="https://github.com/amouzougit" target="_blank" rel="noopener noreferrer"
                       class="text-secondary hover:text-accent text-2xl transition-colors focus:outline-none focus:ring-2 focus:ring-accent rounded-full p-1" aria-label="GitHub">
                        <i class="ph ph-github-logo" aria-hidden="true"></i>
                    </a>
                    <a href="mailto:kevoamouzou@gmail.com"
                       class="text-secondary hover:text-accent text-2xl transition-colors focus:outline-none focus:ring-2 focus:ring-accent rounded-full p-1" aria-label="Email">
                        <i class="ph ph-envelope-simple" aria-hidden="true"></i>
                    </a>
                </div>

                <p class="text-center text-xs text-secondary/40 mt-5">
                    kevoamouzou@gmail.com &nbsp;·&nbsp; +33 780 866 575 &nbsp;·&nbsp; Belfort, France
                </p>
            </div>
        </div>
